REDIS_URL=redis://127.0.0.1:6379
# Directory where designer uploads of baked map surface images are written.
# Must point at the asset-storage server's map-assets folder — the nginx
# asset server (see ../asset-storage) serves them at
# ${ASSET_STORAGE_BASE_URL}/map-assets/<mapId>/<file>; this server no longer
# serves files itself. Defaults to ./map-assets when unset.
ASSET_STORAGE_URL=../asset-storage/assets/map-assets
JWT_SECRET=change-me
AUTH_PEPPER=
AUTH_SESSION_TTL_SECONDS=604800
AUTH_EMAIL_VALIDATION_TTL_SECONDS=86400
AUTH_PASSWORD_RESET_TTL_SECONDS=3600

APP_PUBLIC_URL=http://localhost:3000
EMAIL_VALIDATION_PATH=/#/validate-email
PASSWORD_RESET_PATH=/#/recover-password

SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@example.com

# --- pokecraft-api (authoritative data store) -------------------------------
# Base URL of the Quarkus API and the admin-scoped API key this server uses to
# manage keys on behalf of admins. The admin key must match a key with `admin`
# scope in pokecraft-api (or its bootstrap POKECRAFT_AUTH_ADMIN_KEY). Keep it
# server-side only — the browser never sees it.
POKECRAFT_API_URL=http://localhost:8080
POKECRAFT_API_ADMIN_KEY=
